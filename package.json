{
  "name": "convex-route-query",
  "version": "0.1.0",
  "description": "Type-safe Convex query helpers for TanStack Router loaders and React Query Suspense.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "concurrently --raw --names tsdown \"bun run build:tsdown\"",
    "build:tsdown": "tsdown",
    "ci": "bun run ci:test && bun run build && bun run lint:pkg",
    "ci:test": "concurrently --raw --names runtime,types,e2e,xo \"bun run ci:test:runtime\" \"bun run ci:test:types\" \"bun run ci:test:e2e\" \"bun run ci:test:xo\"",
    "ci:test:e2e": "bun run test:e2e:tanstack-start",
    "ci:test:runtime": "vitest run",
    "ci:test:types": "tsc --noEmit",
    "ci:test:xo": "xo",
    "dev": "concurrently --raw --names tsdown \"bun run dev:tsdown\"",
    "dev:tsdown": "tsdown --watch",
    "lint:pkg": "concurrently --raw --names publint,attw \"bun run lint:pkg:publint\" \"bun run lint:pkg:attw\"",
    "lint:pkg:attw": "attw --pack .",
    "lint:pkg:publint": "publint",
    "prepublishOnly": "bun run ci",
    "release": "bun run build && changeset publish",
    "test": "concurrently --raw --names runtime,types,e2e,xo \"bun run test:runtime\" \"bun run test:types\" \"bun run test:e2e:tanstack-start\" \"bun run test:xo\"",
    "test:e2e:tanstack-start": "tsc -p e2e/tanstack-start/tsconfig.json --noEmit",
    "test:runtime": "vitest run",
    "test:types": "tsc --noEmit",
    "test:xo": "xo",
    "typecheck": "bun run test:types",
    "version": "changeset version && bun install --lockfile-only"
  },
  "keywords": [
    "convex",
    "tanstack",
    "tanstack-router",
    "react-query",
    "suspense",
    "typescript"
  ],
  "author": "ludicrous",
  "license": "MIT",
  "homepage": "https://github.com/ludicroushq/convex-route-query#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludicroushq/convex-route-query.git"
  },
  "bugs": {
    "url": "https://github.com/ludicroushq/convex-route-query/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.14",
  "peerDependencies": {
    "@convex-dev/react-query": ">=0.1.0",
    "@tanstack/react-query": ">=5.0.0",
    "convex": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@convex-dev/react-query": "^0.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "convex": "^1.41.0",
    "expect-type": "^1.3.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.8",
    "xo": "^2.0.2",
    "zod": "^4.4.3"
  }
}
