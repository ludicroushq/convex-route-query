{
  "name": "convex-route-query",
  "version": "0.1.1",
  "description": "Type-safe helpers for prefetching Convex queries in TanStack Router loaders and reusing the typed args in route components.",
  "keywords": [
    "convex",
    "convex-query",
    "prefetch",
    "react",
    "react-query",
    "route-loader",
    "suspense",
    "tanstack",
    "tanstack-query",
    "tanstack-router",
    "tanstack-start",
    "typescript"
  ],
  "homepage": "https://github.com/ludicroushq/convex-route-query#readme",
  "bugs": {
    "url": "https://github.com/ludicroushq/convex-route-query/issues"
  },
  "license": "MIT",
  "author": "ludicrous",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludicroushq/convex-route-query.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "concurrently --raw --names tsdown \"bun run build:tsdown\"",
    "build:tsdown": "tsdown",
    "ci": "bun run ci:test && bun run build && bun run lint:pkg",
    "ci:test": "concurrently --raw --names runtime,types,e2e,ultracite \"bun run ci:test:runtime\" \"bun run ci:test:types\" \"bun run ci:test:e2e\" \"bun run ci:test:ultracite\"",
    "ci:test:e2e": "bun run test:e2e:tanstack-start",
    "ci:test:runtime": "vitest run",
    "ci:test:types": "tsc --noEmit",
    "ci:test:ultracite": "ultracite check",
    "dev": "concurrently --raw --names tsdown \"bun run dev:tsdown\"",
    "dev:tsdown": "tsdown --watch",
    "lint:pkg": "concurrently --raw --names publint,attw \"bun run lint:pkg:publint\" \"bun run lint:pkg:attw\"",
    "lint:pkg:attw": "attw --pack .",
    "lint:pkg:publint": "publint",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run ci",
    "release": "bun run build && changeset publish",
    "test": "concurrently --raw --names runtime,types,e2e,ultracite \"bun run test:runtime\" \"bun run test:types\" \"bun run test:e2e:tanstack-start\" \"bun run test:ultracite\"",
    "test:e2e:tanstack-start": "tsc -p e2e/tanstack-start/tsconfig.json --noEmit",
    "test:runtime": "vitest run",
    "test:types": "tsc --noEmit",
    "test:ultracite": "ultracite check",
    "typecheck": "bun run test:types",
    "ultracite": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "version": "changeset version && bun install --lockfile-only"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@convex-dev/react-query": "^0.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "convex": "^1.41.0",
    "expect-type": "^1.3.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "ultracite": "7.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@convex-dev/react-query": ">=0.1.0",
    "@tanstack/react-query": ">=5.0.0",
    "convex": ">=1.0.0",
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.14"
}
